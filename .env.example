# --- User-specific settings (MUST edit before first use) ---
PJM_PROJECT=EDIT_ME                 # 計算科学アライアンスのプロジェクト名
PJM_USER=EDIT_ME                    # Wisteria ユーザ名
WORK_DIR=/work/${PJM_PROJECT}/${PJM_USER}
PROJECT_ROOT=${WORK_DIR}/wisteria-qwen35-4gpu

# --- Derived paths (usually no need to change) ---
VENV_DIR=$PROJECT_ROOT/.venv

HF_HOME=$PROJECT_ROOT/runtime/hf
HUGGINGFACE_HUB_CACHE=$PROJECT_ROOT/runtime/hf/hub
TRANSFORMERS_CACHE=$PROJECT_ROOT/runtime/hf/transformers
VLLM_CONFIG_ROOT=$PROJECT_ROOT/runtime/vllm
TMPDIR=$PROJECT_ROOT/tmp

# --- Model / server ---
MODEL_ID=Qwen/Qwen3.5-35B-A3B
HOST=0.0.0.0
PORT=8000
API_KEY=EMPTY

TENSOR_PARALLEL_SIZE=4
DTYPE=bfloat16
MAX_MODEL_LEN=4096
GPU_MEMORY_UTILIZATION=0.90
